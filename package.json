{
  "name": "cc-in-codex",
  "version": "0.1.0",
  "description": "Local MCP server that gives Codex a persistent Claude Code companion session.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cc-in-codex": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "keywords": [
    "codex",
    "claude-code",
    "mcp",
    "developer-tools",
    "agent"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.193",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22"
  }
}
